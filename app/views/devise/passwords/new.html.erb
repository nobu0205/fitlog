<div class="login-hero">
  <div class="overlay">
    <h2>パスワードをお忘れですか？</h2>

    <p style="margin-bottom: 20px;">
      登録しているメールアドレスを入力してください。<br>
      パスワード再設定用のリンクを送信します。
    </p>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>

      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="field">
        <label>メールアドレス</label>
        <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              placeholder: "example@email.com",
              class: "form-input" %>
      </div>

      <div class="actions" style="margin-top: 20px;">
        <%= f.submit "送信する", class: "btn btn-primary btn-full" %>
      </div>

    <% end %>

    <div class="links">
      <%= link_to "ログインに戻る", new_session_path(resource_name), class: "btn btn-sm btn-success" %>
    </div>
  </div>
</div>
