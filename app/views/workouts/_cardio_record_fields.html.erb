<div class="cardio-record-fields border p-2 mb-2 relative">
  <button type="button" data-action="click->cardio-form#remove" class="absolute right-0 top-0 px-2 py-1 bg-red-500 text-white rounded">×</button>

  <%= f.hidden_field :_destroy %>

  <div>
    <%= f.label :exercise_id, "種目" %>
    <%= f.collection_select :exercise_id, exercises, :id, :name, prompt: "選択してください" %>
  </div>

  <div>
    <%= f.label :speed, "速度(km/h)" %>
    <%= f.number_field :speed, step: 0.1 %>
  </div>

  <div>
    <%= f.label :duration, "所要時間(分)" %>
    <%= f.number_field :duration %>
  </div>

  <div>
    <%= f.label :distance, "距離(km)" %>
    <%= f.number_field :distance, step: 0.01 %>
  </div>
</div>