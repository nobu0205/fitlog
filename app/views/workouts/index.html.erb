<div class="workouts-hero">
  <div class="overlay">
    <h1>ワークアウト一覧</h1>


    <% if @workouts.any? %>
      <div class="workouts-list">
        <% @workouts.each do |workout| %>
          <% strength_total = workout.strength_records.sum { |sr| sr.calories.to_f } %>
          <% cardio_total = workout.cardio_records.sum { |cr| cr.calories.to_f } %>
          <% total_calories = strength_total + cardio_total %>

          <div class="workout-card">
            <div class="card-header">
              <strong><%= workout.date.strftime("%Y/%m/%d") %></strong>
              <span class="total-calories">合計消費: <%= total_calories.round(1) %> kcal</span>
            </div>

            <% if workout.memo.present? %>
              <p class="memo"><%= workout.memo %></p>
            <% end %>

            <!-- 筋トレ -->
            <% if workout.strength_records.any? %>
              <div class="exercise-section strength">
                <h4>💪 筋トレ</h4>
                <ul>
                  <% workout.strength_records.each do |sr| %>
                    <li><%= sr.exercise&.name %>：<%= sr.weight %>kg × <%= sr.reps %>回 × <%= sr.sets %>セット (<%= sr.calories.to_f.round(1) %> kcal)</li>
                  <% end %>
                </ul>
                <p class="section-total">筋トレ合計: <%= strength_total.round(1) %> kcal</p>
              </div>
            <% end %>

            <!-- 有酸素 -->
            <% if workout.cardio_records.any? %>
              <div class="exercise-section cardio">
                <h4>🏃 有酸素</h4>
                <ul>
                  <% workout.cardio_records.each do |cr| %>
                    <li><%= cr.exercise&.name %>：<%= cr.distance %>km / <%= cr.duration %>分 (<%= cr.calories.to_f.round(1) %> kcal)</li>
                  <% end %>
                </ul>
                <p class="section-total">有酸素合計: <%= cardio_total.round(1) %> kcal</p>
              </div>
            <% end %>

            <!-- 編集・削除 -->
            <div class="card-actions">
              <%= link_to "編集", edit_workout_path(workout), class: "btn btn-sm btn-primary" %>
              <%= link_to "削除", workout_path(workout), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class: "btn btn-sm btn-danger" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p>まだワークアウトは登録されていません。</p>
    <% end %>
  </div>
</div>